---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { profile } from '../data/profile.ts';

const pubs = await getCollection('publications');
const publications = pubs.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout>
  <!-- NAV -->
  <nav class="sticky top-0 z-50 bg-forest-900/90 backdrop-blur-sm border-b border-forest-700/60">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <span class="font-semibold tracking-tight text-sage-100">Serena Cofano</span>
      <div class="flex items-center gap-6 text-sm">
        <a href="#publications" class="text-sage-300 hover:text-amber-400 transition-colors hidden sm:block">Publications</a>
        <a href="#experience" class="text-sage-300 hover:text-amber-400 transition-colors hidden sm:block">Experience</a>
        <a href="#activities" class="text-sage-300 hover:text-amber-400 transition-colors hidden sm:block">Activities</a>
        <a
          href={profile.cv}
          target="_blank"
          rel="noopener noreferrer"
          class="border border-amber-400/50 text-amber-400 hover:bg-amber-400/10 px-3 py-1.5 rounded-md transition-colors font-medium text-xs"
        >
          CV ↗
        </a>
      </div>
    </div>
  </nav>

  <main>
    <!-- HERO -->
    <section id="about" class="max-w-5xl mx-auto px-6 py-20 md:py-28">
      <div class="flex flex-col-reverse md:flex-row items-center gap-12 md:gap-20">

        <!-- Text -->
        <div class="flex-1 space-y-6">
          <div>
            <h1 class="text-5xl md:text-6xl font-bold tracking-tight text-sage-100 leading-none">
              Serena<br />Cofano
            </h1>
            <p class="mt-4 text-amber-400 font-medium text-lg">{profile.tagline}</p>
            <p class="mt-2 text-sage-400 text-sm flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              {profile.location}
            </p>
          </div>

          <p class="text-sage-200 leading-relaxed max-w-lg text-[15px]">{profile.bio}</p>

          <div class="flex flex-wrap gap-3 pt-1">
            <a
              href={profile.cv}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-amber-400 text-forest-900 font-semibold px-5 py-2.5 rounded-lg hover:bg-amber-300 transition-colors text-sm"
            >
              Download CV
            </a>
            <a
              href={`mailto:${profile.email}`}
              class="border border-moss-600 text-sage-200 px-5 py-2.5 rounded-lg hover:bg-forest-700 transition-colors text-sm"
            >
              Get in touch
            </a>
          </div>

          <!-- Social links -->
          <div class="flex items-center gap-5 pt-1">
            <a href={profile.links.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-sage-400 hover:text-sage-100 transition-colors">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
            </a>
            <a href={profile.links.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-sage-400 hover:text-sage-100 transition-colors">
              <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            <a href={profile.links.scholar} target="_blank" rel="noopener noreferrer" class="text-sage-400 hover:text-sage-100 transition-colors text-xs font-semibold tracking-wide">
              Scholar ↗
            </a>
          </div>
        </div>

        <!-- Photo -->
        <div class="flex-shrink-0">
          <div class="w-44 h-44 md:w-52 md:h-52 rounded-full overflow-hidden ring-4 ring-moss-600 ring-offset-8 ring-offset-forest-900">
            <img src={profile.photo} alt="Serena Cofano" class="w-full h-full object-cover" />
          </div>
        </div>

      </div>
    </section>

    <!-- PUBLICATIONS -->
    <section id="publications" class="bg-forest-800 py-20">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-sage-100 mb-2">Publications</h2>
        <p class="text-sage-400 text-sm mb-10">Research on software supply chain security, SBOM, and vulnerability assessment.</p>
        <div class="space-y-4">
          {publications.map((pub) => (
            <article class="bg-forest-700 rounded-xl p-6 border border-forest-600/30 hover:border-moss-700/60 transition-colors">
              <div class="flex flex-wrap gap-3 items-center mb-3">
                <span class="bg-amber-400/10 text-amber-400 text-xs font-semibold px-2.5 py-1 rounded-md border border-amber-400/25">
                  {pub.data.venue}
                </span>
                <span class="text-sage-400 text-xs">{pub.data.date.getFullYear()} · {pub.data.location}</span>
              </div>
              <h3 class="text-sage-100 font-semibold text-base md:text-lg mb-2 leading-snug">{pub.data.title}</h3>
              <p class="text-sm mb-4 leading-relaxed">
                {pub.data.authors.map((author, i) => (
                  <>
                    <span class={author === 'Serena Cofano' ? 'text-amber-400 font-medium' : 'text-sage-300'}>
                      {author}
                    </span>{i < pub.data.authors.length - 1 && <span class="text-sage-500"> · </span>}
                  </>
                ))}
              </p>
              <div class="flex flex-wrap gap-2">
                {pub.data.pdf && (
                  <a href={pub.data.pdf} target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1.5 rounded-md bg-forest-600 hover:bg-forest-500 text-sage-200 transition-colors border border-forest-500/30">PDF</a>
                )}
                {pub.data.slides && (
                  <a href={pub.data.slides} target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1.5 rounded-md bg-forest-600 hover:bg-forest-500 text-sage-200 transition-colors border border-forest-500/30">Slides</a>
                )}
                {pub.data.code && (
                  <a href={pub.data.code} target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1.5 rounded-md bg-forest-600 hover:bg-forest-500 text-sage-200 transition-colors border border-forest-500/30">Code ↗</a>
                )}
                {pub.data.doi && (
                  <a href={pub.data.doi} target="_blank" rel="noopener noreferrer" class="text-xs px-3 py-1.5 rounded-md bg-moss-700/40 hover:bg-moss-700/70 text-sage-100 transition-colors border border-moss-600/30">DOI ↗</a>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- EXPERIENCE + EDUCATION -->
    <section id="experience" class="py-20">
      <div class="max-w-5xl mx-auto px-6 space-y-14">

        <!-- Experience -->
        <div>
          <h2 class="text-3xl font-bold text-sage-100 mb-8">Experience</h2>
          <div class="space-y-7">
            {profile.experience.map((exp) => (
              <div class="border-l-2 border-moss-700 pl-5 space-y-1">
                <p class="text-amber-400 text-xs font-semibold tracking-widest uppercase">{exp.period}</p>
                <h3 class="text-sage-100 font-semibold text-[15px]">{exp.role}</h3>
                <p class="text-sage-300 text-sm">{exp.org}</p>
                <p class="text-sage-400 text-sm leading-relaxed">{exp.description}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Education -->
        <div>
          <h2 class="text-3xl font-bold text-sage-100 mb-8">Education</h2>
          <div class="space-y-7">
            {profile.education.map((edu) => (
              <div class="border-l-2 border-moss-700 pl-5 space-y-1">
                <p class="text-amber-400 text-xs font-semibold tracking-widest uppercase">{edu.year}</p>
                <h3 class="text-sage-100 font-semibold text-[15px]">{edu.degree}</h3>
                <p class="text-sage-300 text-sm">{edu.institution}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </section>

    <!-- SKILLS -->
    <section class="bg-forest-800 py-20">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-sage-100 mb-10">Skills</h2>
        <div class="grid sm:grid-cols-3 gap-8">
          {Object.entries(profile.skills).map(([category, items]) => (
            <div>
              <h3 class="text-amber-400 font-semibold text-xs uppercase tracking-widest mb-4">{category}</h3>
              <div class="flex flex-wrap gap-2">
                {(items as string[]).map((skill) => (
                  <span class="bg-forest-700 border border-forest-600/60 text-sage-200 text-sm px-3 py-1.5 rounded-md">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ACTIVITIES -->
    <section id="activities" class="py-20">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-sage-100 mb-10">Activities</h2>

        <div class="grid md:grid-cols-2 gap-12">
          <!-- Conferences -->
          <div>
            <h3 class="text-amber-400 font-semibold text-xs uppercase tracking-widest mb-5">Conferences</h3>
            <div class="space-y-5">
              {profile.activities.conferences.map((conf) => (
                <div class="border-l-2 border-moss-700/50 pl-4">
                  <p class="text-sage-100 text-sm font-medium leading-snug">{conf.name}</p>
                  <p class="text-sage-400 text-xs mt-1">{conf.date} · {conf.location}</p>
                </div>
              ))}
            </div>
          </div>

          <!-- Workshops + Schools -->
          <div class="space-y-10">
            <div>
              <h3 class="text-amber-400 font-semibold text-xs uppercase tracking-widest mb-5">Workshops</h3>
              <div class="space-y-5">
                {profile.activities.workshops.map((ws) => (
                  <div class="border-l-2 border-moss-700/50 pl-4">
                    <p class="text-sage-100 text-sm font-medium leading-snug">{ws.name}</p>
                    <p class="text-sage-400 text-xs mt-1">{ws.date} · {ws.location}</p>
                  </div>
                ))}
              </div>
            </div>
            <div>
              <h3 class="text-amber-400 font-semibold text-xs uppercase tracking-widest mb-5">Summer Schools</h3>
              <div class="space-y-5">
                {profile.activities.schools.map((s) => (
                  <div class="border-l-2 border-moss-700/50 pl-4">
                    <p class="text-sage-100 text-sm font-medium leading-snug">{s.name}</p>
                    <p class="text-sage-400 text-xs mt-1">{s.date} · {s.location}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Teaching -->
        <div class="mt-12">
          <h3 class="text-amber-400 font-semibold text-xs uppercase tracking-widest mb-5">Teaching</h3>
          <div class="grid sm:grid-cols-2 gap-4">
            {profile.activities.teaching.map((t) => (
              <div class="bg-forest-800 border border-forest-600/30 rounded-xl p-5">
                <p class="text-sage-100 font-semibold text-sm">{t.course}</p>
                <p class="text-sage-300 text-sm mt-1">{t.program}</p>
                <p class="text-sage-400 text-xs mt-0.5">{t.institution}</p>
                <p class="text-moss-500 text-xs mt-2 font-medium">{t.period}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- BEYOND THE LAB -->
    <section class="bg-forest-800 py-20">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-sage-100 mb-2">Beyond the Lab</h2>
        <p class="text-sage-400 text-sm mb-10">Research is what I do. Curiosity is who I am.</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">

          <!-- Languages -->
          <div class="bg-forest-700 border border-forest-600/30 rounded-xl p-5 hover:border-moss-700/60 transition-colors">
            <div class="text-moss-500 mb-3">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
              </svg>
            </div>
            <h3 class="text-sage-100 font-semibold text-sm mb-2">Languages</h3>
            <div class="space-y-1">
              <p class="text-sage-300 text-xs">Italian <span class="text-sage-500">— native</span></p>
              <p class="text-sage-300 text-xs">English <span class="text-sage-500">— C1</span></p>
              <p class="text-sage-300 text-xs">French <span class="text-sage-500">— B1</span></p>
              <p class="text-sage-300 text-xs">German · Spanish <span class="text-sage-500">— A2</span></p>
            </div>
          </div>

          <!-- TryHackMe -->
          <a
            href={profile.links.tryhackme}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-forest-700 border border-forest-600/30 rounded-xl p-5 hover:border-moss-700/60 transition-colors block"
          >
            <div class="text-moss-500 mb-3">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="4 17 10 11 4 5"/>
                <line x1="12" y1="19" x2="20" y2="19"/>
              </svg>
            </div>
            <h3 class="text-sage-100 font-semibold text-sm mb-1">TryHackMe <span class="text-moss-500 font-normal">↗</span></h3>
            <p class="text-sage-400 text-xs leading-relaxed">Practicing offensive security through CTF challenges and guided labs.</p>
          </a>

          <!-- Hiking -->
          <div class="bg-forest-700 border border-forest-600/30 rounded-xl p-5 hover:border-moss-700/60 transition-colors">
            <div class="text-moss-500 mb-3">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M3 20l5-9 3.5 4 3-5L19 20H3z"/>
                <path d="M16 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" fill="currentColor" stroke="none"/>
              </svg>
            </div>
            <h3 class="text-sage-100 font-semibold text-sm mb-1">Hiking & Nature</h3>
            <p class="text-sage-400 text-xs leading-relaxed">Mountains, trails, and fresh air whenever possible.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer class="border-t border-forest-700/60 py-8">
      <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sage-500 text-xs">
        <span>© {new Date().getFullYear()} Serena Cofano</span>
        <span>Built with Astro · Belgium</span>
      </div>
    </footer>
  </main>
</Layout>
